{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "butterlog",
  "version": "0.3.3",
  "identifier": "net.flyvoyager.butterlog",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Butterlog flight tracker",
        "width": 1024,
        "height": 768
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNFQjcxQkE5MjY5QjI5MkIKUldRcktac21xUnUzUGtpYUZRUFpnSTVHOGEyVGxsbHFzaVhMMStOSXp6cDlCMlp3c2hDWXU3VjQK",
      "endpoints": ["https://butterlog.flyvoyager.net/downloads/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../public/airports.csv",
      "../public/runways.csv"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  }
}
